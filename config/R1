!
hostname R1
!
enable secret <REDACTED>
!
ip dhcp excluded-address 192.168.10.1 192.168.10.5
ip dhcp excluded-address 192.168.20.1 192.168.20.5
!
ip dhcp pool POOL_10
 network 192.168.10.0 255.255.255.0
 default-router 192.168.10.1
 dns-server 8.8.8.8
!
ip dhcp pool POOL_20
 network 192.168.20.0 255.255.255.0
 default-router 192.168.20.1
 dns-server 8.8.8.8
!
username Admin secret <REDACTED>
!
ip ssh version 2
ip ssh time-out 60
ip domain-name nexgent.com
!
interface GigabitEthernet0/0
 ip address 209.165.200.226 255.255.255.252
 ip nat outside
 duplex auto
 speed auto
!
interface GigabitEthernet0/1
 no ip address
 duplex auto
 speed auto
!
interface GigabitEthernet0/1.10
 encapsulation dot1Q 10
 ip address 192.168.10.1 255.255.255.0
 ip nat inside
!
interface GigabitEthernet0/1.20
 encapsulation dot1Q 20
 ip address 192.168.20.1 255.255.255.0
 ip nat inside
!
interface GigabitEthernet0/1.30
 encapsulation dot1Q 30 native
 ip address 192.168.30.1 255.255.255.0
 ip nat inside
!
interface GigabitEthernet0/2
 shutdown
!
interface Serial0/0/0
 ip address 192.168.2.1 255.255.255.252
 ip nat inside
 clock rate 2000000
!
interface Serial0/0/1
 ip address 192.168.2.10 255.255.255.252
 ip nat inside
 clock rate 2000000
!
router ospf 10
 router-id 1.1.1.1
 log-adjacency-changes
 passive-interface GigabitEthernet0/1.10
 passive-interface GigabitEthernet0/1.20
 passive-interface GigabitEthernet0/1.30
 network 192.168.2.0 0.0.0.3 area 0
 network 192.168.10.0 0.0.0.255 area 0
 network 192.168.20.0 0.0.0.255 area 0
 network 192.168.30.0 0.0.0.255 area 0
 network 192.168.2.8 0.0.0.3 area 0
 default-information originate
!
ip nat inside source list 1 interface GigabitEthernet0/0 overload
ip route 0.0.0.0 0.0.0.0 209.165.200.225
!
access-list 1 permit 192.168.10.0 0.0.0.255
access-list 1 permit 192.168.20.0 0.0.0.255
access-list 1 permit 192.168.30.0 0.0.0.255
access-list 1 permit 172.16.40.0 0.0.0.255
access-list 1 permit 172.16.50.0 0.0.0.255
access-list 1 permit 10.0.70.0 0.0.0.255
access-list 1 permit 10.0.80.0 0.0.0.255
access-list 1 permit 10.0.90.0 0.0.0.255
access-list 1 permit 172.16.150.0 0.0.0.255
!
logging 192.168.30.5
!
line vty 0 4
 login local
 transport input ssh
line vty 5 15
 login local
 transport input ssh
!
ntp authentication-key 1 md5 <REDACTED> 7
ntp authenticate
ntp master
!
end
